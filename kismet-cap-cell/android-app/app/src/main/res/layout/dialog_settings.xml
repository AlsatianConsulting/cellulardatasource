<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/transportModeLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Transport mode: USB"
        android:textStyle="bold" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchStreamCell"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Stream cellular data"
        android:layout_marginTop="8dp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchStreamGps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Stream GPS data"
        android:layout_marginTop="8dp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchAutoStart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Auto-stream on launch"
        android:layout_marginTop="8dp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchStartOnBoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Begin on startup"
        android:layout_marginTop="8dp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchLaunchUiOnBoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Launch app UI on startup"
        android:layout_marginTop="8dp" />

</LinearLayout>
